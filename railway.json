{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements.txt && python manage.py collectstatic --noinput && python ml/predictor.py"
  },
  "deploy": {
    "startCommand": "python manage.py migrate --noinput && daphne -b 0.0.0.0 -p $PORT medicate.asgi:application",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}