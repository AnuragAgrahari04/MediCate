# Copy this to .env and fill in your values
SECRET_KEY=your-secret-key-here-generate-with-django
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# Database (Supabase PostgreSQL recommended)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOURPROJECT.supabase.co:5432/postgres

# Redis (optional - for WebSocket scaling in production)
# REDIS_URL=redis://...

# Cloudinary (for persistent media/image storage in production)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Agora Video SDK - get free keys at https://console.agora.io
AGORA_APP_ID=your_agora_app_id_here
AGORA_APP_CERT=your_agora_app_certificate_here

# OpenRouter AI (Gemini) - get free key at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Maps (optional, for enhanced map features)
# GOOGLE_MAPS_KEY=your_google_maps_key_here

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password-here

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Daily.co Video
DAILY_API_KEY=your_daily_api_key_here