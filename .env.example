# Copy this to .env and fill in your values
SECRET_KEY=django-insecure-replace-this-with-a-real-secret-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Redis (uncomment to use Redis channel layers for WebSocket in production)
# REDIS_URL=redis://127.0.0.1:6379

# Agora Video SDK – get free keys at https://console.agora.io
# AGORA_APP_ID=your_agora_app_id_here
# AGORA_APP_CERT=your_agora_app_certificate_here

# OpenRouter AI (Gemini) – get free key at https://openrouter.ai
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Maps (optional, for enhanced map features)
# GOOGLE_MAPS_KEY=your_google_maps_key_here
